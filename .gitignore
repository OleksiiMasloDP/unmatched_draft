# Зависимости (их никогда не пушим, они ставятся через npm install)
node_modules/
jspm_packages/
web_modules/

# Локальные файлы окружения (могут содержать секретные ключи, пароли и API-токены)
.env
.env.local
.env.*.local

# Папки сборки (билды, которые генерируются автоматически)
dist/
build/

# Логи ошибок
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Настройки редакторов кода (IDE)
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Системные файлы
.DS_Store
Thumbs.db